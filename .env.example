# =====================================================
#  Agent Mission Control — 환경 설정
#  이 파일을 .env로 복사한 뒤 값을 변경하세요.
#  cp .env.example .env
# =====================================================

# ── 서버 및 보안 ──────────────────────────────────────
PORT=4000
DASHBOARD_PASSWORD=your-strong-password-here
JWT_SECRET=your-very-long-random-secret-key-here-change-this
TOKEN_EXPIRY=24h
ALLOWED_ORIGIN=*

# ── 프로젝트 루트 경로 ────────────────────────────────
# 관제 대상 프로젝트들의 최상위 폴더 (서버 기준 절대 경로)
PROJECT_ROOT=/root

# ── AI 에이전트 설정 (OpenRouter) ─────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# 예산 한도 (USD) — 관리자가 자유롭게 설정
BUDGET_LIMIT_USD=10

# 에이전트 역할별 모델 (OpenRouter Model ID)
# → 필요에 따라 추가/교체/삭제 자유
AGENT_ARCHITECT=openai/o3-mini
AGENT_ORCHESTRATOR=anthropic/claude-3.5-sonnet
AGENT_WORKER=moonshot/kimi-2.5
AGENT_DESIGNER=google/gemini-2.5-pro
AGENT_REVIEWER=qwen/qwen-2.5-coder-32b-instruct
AGENT_INTEGRATOR=anthropic/claude-3.5-sonnet

# ── 배포 및 알림 ──────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── GitHub 자동 PR ────────────────────────────────────
# GitHub PAT (repo 권한 필요): https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
# 레포 정보 (github.com/OWNER/REPO)
GITHUB_OWNER=leejun-cloud
GITHUB_REPO=famiy-achive
GITHUB_BASE_BRANCH=main
# 워커가 생성한 파일을 프로젝트에 자동 적용할지 여부 (true/false)
AUTO_APPLY_FILES=true

# ── Vercel 배포 (선택) ───────────────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
